{
  "name": "seguranca-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm env:load tsx --watch src/infra/http/server.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "db:generate": "pnpm env:load drizzle-kit generate",
    "db:migrate": "pnpm env:load drizzle-kit migrate",
    "db:push": "pnpm env:load drizzle-kit push",
    "db:studio": "pnpm env:load drizzle-kit studio",
    "env:load": "dotenv -e ./.env -- "
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@scalar/fastify-api-reference": "^1.52.1",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.20",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "fastify-type-provider-zod": "^6.1.0",
    "nanoid": "^5.1.7",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "resend": "^6.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}